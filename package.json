{
  "name": "chambar",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "deploy": "wrangler pages deploy .svelte-kit/cloudflare",
    "dev": "vite dev",
    "dev:cf": "wrangler pages dev .svelte-kit/cloudflare",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:init": "node scripts/init-db.js",
    "db:create": "wrangler d1 create chambar-dev",
    "db:list": "wrangler d1 list",
    "db:query": "wrangler d1 execute chambar-dev --command",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute chambar-dev --file=src/lib/db/schema.sql --local",
    "db:migrate:remote": "wrangler d1 execute chambar-dev --file=src/lib/db/schema.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@skeletonlabs/tw-plugin": "^0.4.1",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.0.0",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.58.0",
    "chart.js": "^4.5.0",
    "drizzle-orm": "^0.45.2",
    "lightweight-charts": "^5.0.9",
    "xlsx": "^0.18.5"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
